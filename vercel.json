{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install --legacy-peer-deps",
  "rewrites": [
    {
      "source": "/seafile-proxy/(.*)",
      "destination": "https://cloud.rbpartners.kz/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}