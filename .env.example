# Frontend Supabase config (safe example, no real secrets)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Server/admin scripts. Do not expose service role keys in frontend code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend auth hardening. Keep false until every employee has a Supabase Auth account
# with role in app_metadata.role or user_metadata.role; then set true in production.
REQUIRE_SUPABASE_JWT=false

# Seafile helper scripts
SEAFILE_URL=https://your-seafile.example.com
SEAFILE_USERNAME=crm-service-user@example.com
SEAFILE_PASSWORD=change-me
SEAFILE_TOKEN=your-seafile-api-token
SEAFILE_REPO_ID=your-seafile-repo-id
